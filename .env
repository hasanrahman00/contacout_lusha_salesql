USER_DATA_DIR=C:\Chrome_Scraper
CDP_PORT=9222

# ── CDP Host (don't change unless running in Docker) ─────────────────────────
# CDP_HOST=127.0.0.1

# ── API Keys ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-f2cc8cf5ef954380b244ff36370eca3b

